        "jsCode": "// Get the blueprint text\nconst blueprint = $input.first().json.output;\n\n// Replace markdown symbols and tidy up (example: remove backslashes)\nconst cleanedOutline = blueprint.replace(/\\\\n/g, \"\\n\").replace(/[*_]/g, \"\");\n\n// Output the cleaned text\nitems[0].json.cleanedOutline = cleanedOutline;\n\nreturn items;\n\n"
