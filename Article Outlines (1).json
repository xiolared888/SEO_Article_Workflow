      "id": "60ac8db7-94d6-4fe8-b5de-9f881496a9fe",
      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items) {\n  let text = item.json.output;\n\n  // 1. Convert escaped newlines\n  text = text.replace(/\\\\n/g, '\\n');\n\n  // 2. Remove weird invisible unicode characters\n  text = text.replace(/[\\u200B-\\u200D\\uFEFF]/g, '');\n\n  // 3. Normalize all line breaks\n  text = text.replace(/\\r\\n/g, '\\n');\n  text = text.replace(/\\r/g, '\\n');\n\n  // 4. Remove markdown formatting\n  text = text.replace(/\\*\\*(.*?)\\*\\*/g, '$1');\n  text = text.replace(/\\*(.*?)\\*/g, '$1');\n  text = text.replace(/^#{1,6}\\s*/gm, '');\n\n  // 5. Fix spacing issues\n  text = text.replace(/\\n{3,}/g, '\\n\\n');\n\n  // 6. FORCE proper paragraph structure\n  text = text.split('\\n').map(line => line.trim()).join('\\n');\n\n  // 7. Final cleanup\n  text = text.trim();\n\n  item.json.cleaned_text = text;\n}\n\nreturn items;\n\n"
      },
